LLM_TYPE=openai
LLM_TEMPERATURE=0
LLM_TIMEOUT=30
LLM_MAX_RETRIES=2

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=your-openai-api-key
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_CHAT_MODEL=qwen-turbo-latest
QWEN_EMBEDDING_MODEL=text-embedding-v1

ONEAPI_BASE_URL=http://127.0.0.1:3000/v1
ONEAPI_API_KEY=
ONEAPI_CHAT_MODEL=qwen-max
ONEAPI_EMBEDDING_MODEL=text-embedding-v1

OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

DB_URI=postgresql://postgres:your-password@127.0.0.1:5432/postgres?sslmode=disable
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=10

MILVUS_URI=http://127.0.0.1:19530
MILVUS_DB_NAME=milvus_database
MILVUS_COLLECTION_NAME=my_collection_demo_chunked

PROJECT_NAME=ResearchFlowAgent
REPORTS_DIR=reports
PREFERENCES_DIR=preferences
DEFAULT_USER_ID=user_001

MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8010

API_SERVER_HOST=0.0.0.0
API_SERVER_PORT=8202
